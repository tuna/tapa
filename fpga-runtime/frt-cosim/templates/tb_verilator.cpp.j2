#include "V{{ top_name }}.h"
#include "verilated.h"
#include <algorithm>
#include <array>
#include <cstdint>
#include <cstdio>
#include <cstring>

extern "C" {
void tapa_axi_read(const char* port, uint64_t addr, uint32_t width, uint8_t* out);
void tapa_axi_write(const char* port, uint64_t addr, uint32_t width, const uint8_t* data);
bool tapa_stream_try_read(const char* port, uint8_t* out);
bool tapa_stream_try_write(const char* port, const uint8_t* data);
bool tapa_stream_can_write(const char* port);
}

static V{{ top_name }}* dut;

struct AxiReadPort {
  bool busy = false;
  uint64_t addr = 0;
  uint8_t len = 0;
  uint8_t beat = 0;
  uint8_t id = 0;
};

struct AxiWritePort {
  bool aw_got = false;
  bool b_pending = false;
  uint64_t addr = 0;
  uint8_t beat = 0;
  uint8_t id = 0;
};

{% for arg in mmap_args %}
static AxiReadPort rd_{{ arg.name }};
static AxiWritePort wr_{{ arg.name }};
{% endfor %}

{% for arg in stream_args %}
static bool stream_in_have_{{ arg.name }} = false;
static std::array<uint8_t, {{ arg.width_bytes }}> stream_in_data_{{ arg.name }} = {};
{% endfor %}

static void tick() {
  dut->ap_clk = 1;
  dut->eval();
  dut->ap_clk = 0;
  dut->eval();
}

static void service_all_axi() {
{% for arg in mmap_args %}
  dut->m_axi_{{ arg.name }}_ARREADY = !rd_{{ arg.name }}.busy;
  if (dut->m_axi_{{ arg.name }}_ARVALID && dut->m_axi_{{ arg.name }}_ARREADY) {
    rd_{{ arg.name }}.busy = true;
    rd_{{ arg.name }}.addr = dut->m_axi_{{ arg.name }}_ARADDR;
    rd_{{ arg.name }}.len = dut->m_axi_{{ arg.name }}_ARLEN;
    rd_{{ arg.name }}.id = dut->m_axi_{{ arg.name }}_ARID;
    rd_{{ arg.name }}.beat = 0;
  }
  if (rd_{{ arg.name }}.busy) {
    std::array<uint8_t, {{ arg.data_width_bytes }}> rdata{};
    tapa_axi_read("{{ arg.name }}",
                  rd_{{ arg.name }}.addr + (uint64_t)rd_{{ arg.name }}.beat * {{ arg.data_width_bytes }},
                  {{ arg.data_width_bytes }},
                  rdata.data());
    std::memcpy(&dut->m_axi_{{ arg.name }}_RDATA, rdata.data(), {{ arg.data_width_bytes }});
    dut->m_axi_{{ arg.name }}_RVALID = 1;
    dut->m_axi_{{ arg.name }}_RLAST = rd_{{ arg.name }}.beat == rd_{{ arg.name }}.len ? 1 : 0;
    dut->m_axi_{{ arg.name }}_RID = rd_{{ arg.name }}.id;
    dut->m_axi_{{ arg.name }}_RRESP = 0;
    if (dut->m_axi_{{ arg.name }}_RREADY) {
      if (rd_{{ arg.name }}.beat >= rd_{{ arg.name }}.len) {
        rd_{{ arg.name }}.busy = false;
      } else {
        rd_{{ arg.name }}.beat++;
      }
    }
  } else {
    dut->m_axi_{{ arg.name }}_RVALID = 0;
  }

  dut->m_axi_{{ arg.name }}_AWREADY = (!wr_{{ arg.name }}.aw_got && !wr_{{ arg.name }}.b_pending) ? 1 : 0;
  if (dut->m_axi_{{ arg.name }}_AWVALID && dut->m_axi_{{ arg.name }}_AWREADY) {
    wr_{{ arg.name }}.aw_got = true;
    wr_{{ arg.name }}.addr = dut->m_axi_{{ arg.name }}_AWADDR;
    wr_{{ arg.name }}.id = dut->m_axi_{{ arg.name }}_AWID;
    wr_{{ arg.name }}.beat = 0;
  }
  dut->m_axi_{{ arg.name }}_WREADY = wr_{{ arg.name }}.aw_got ? 1 : 0;
  if (dut->m_axi_{{ arg.name }}_WVALID && dut->m_axi_{{ arg.name }}_WREADY) {
    std::array<uint8_t, {{ arg.data_width_bytes }}> wdata{};
    std::memcpy(wdata.data(), &dut->m_axi_{{ arg.name }}_WDATA, {{ arg.data_width_bytes }});
    tapa_axi_write("{{ arg.name }}",
                   wr_{{ arg.name }}.addr + (uint64_t)wr_{{ arg.name }}.beat * {{ arg.data_width_bytes }},
                   {{ arg.data_width_bytes }},
                   wdata.data());
    wr_{{ arg.name }}.beat++;
    if (dut->m_axi_{{ arg.name }}_WLAST) {
      wr_{{ arg.name }}.aw_got = false;
      wr_{{ arg.name }}.b_pending = true;
    }
  }
  dut->m_axi_{{ arg.name }}_BVALID = wr_{{ arg.name }}.b_pending ? 1 : 0;
  dut->m_axi_{{ arg.name }}_BID = wr_{{ arg.name }}.id;
  dut->m_axi_{{ arg.name }}_BRESP = 0;
  if (wr_{{ arg.name }}.b_pending && dut->m_axi_{{ arg.name }}_BREADY) {
    wr_{{ arg.name }}.b_pending = false;
  }
{% endfor %}
}

{% if mode == "vitis" %}
static void ctrl_write(uint8_t addr, uint32_t data) {
  dut->s_axi_control_AWVALID = 1;
  dut->s_axi_control_AWADDR = addr;
  dut->s_axi_control_WVALID = 1;
  dut->s_axi_control_WDATA = data;
  dut->s_axi_control_WSTRB = 0xF;
  dut->s_axi_control_BREADY = 1;
  for (int i = 0; i < 64; ++i) {
    service_all_axi();
    tick();
    if (dut->s_axi_control_BVALID) break;
  }
  dut->s_axi_control_AWVALID = 0;
  dut->s_axi_control_WVALID = 0;
  dut->s_axi_control_BREADY = 0;
  service_all_axi();
  tick();
}
{% endif %}

static void service_streams() {
{% if mode == "hls" %}
{% for arg in stream_args %}
  if (!stream_in_have_{{ arg.name }}) {
    stream_in_have_{{ arg.name }} = tapa_stream_try_read("{{ arg.name }}", stream_in_data_{{ arg.name }}.data());
  }
  dut->{{ arg.name }}_empty_n = stream_in_have_{{ arg.name }} ? 1 : 0;
{% if arg.has_peek %}
  dut->{{ arg.peek_name }}_empty_n = stream_in_have_{{ arg.name }} ? 1 : 0;
{% endif %}
  if (stream_in_have_{{ arg.name }}) {
    std::memcpy(&dut->{{ arg.name }}_dout, stream_in_data_{{ arg.name }}.data(), {{ arg.width_bytes }});
{% if arg.has_peek %}
    std::memcpy(&dut->{{ arg.peek_name }}_dout, stream_in_data_{{ arg.name }}.data(), {{ arg.width_bytes }});
{% endif %}
  }
  if (stream_in_have_{{ arg.name }} && dut->{{ arg.name }}_read) {
    stream_in_have_{{ arg.name }} = false;
  }
{% endfor %}
{% for arg in stream_out_args %}
  bool can_write_{{ arg.name }} = tapa_stream_can_write("{{ arg.name }}");
  dut->{{ arg.name }}_full_n = can_write_{{ arg.name }} ? 1 : 0;
  if (dut->{{ arg.name }}_write && can_write_{{ arg.name }}) {
    std::array<uint8_t, {{ arg.width_bytes }}> data{};
    std::memcpy(data.data(), &dut->{{ arg.name }}_din, {{ arg.width_bytes }});
    (void)tapa_stream_try_write("{{ arg.name }}", data.data());
  }
{% endfor %}
{% else %}
{% for arg in stream_args %}
  if (!stream_in_have_{{ arg.name }}) {
    stream_in_have_{{ arg.name }} = tapa_stream_try_read("{{ arg.name }}", stream_in_data_{{ arg.name }}.data());
  }
  dut->{{ arg.name }}_TVALID = stream_in_have_{{ arg.name }} ? 1 : 0;
  dut->{{ arg.name }}_TLAST = 0;
  if (stream_in_have_{{ arg.name }}) {
    std::memcpy(&dut->{{ arg.name }}_TDATA, stream_in_data_{{ arg.name }}.data(), {{ arg.width_bytes }});
  }
  if (stream_in_have_{{ arg.name }} && dut->{{ arg.name }}_TREADY) {
    stream_in_have_{{ arg.name }} = false;
  }
{% endfor %}
{% for arg in stream_out_args %}
  dut->{{ arg.name }}_TREADY = tapa_stream_can_write("{{ arg.name }}") ? 1 : 0;
  if (dut->{{ arg.name }}_TVALID && dut->{{ arg.name }}_TREADY) {
    std::array<uint8_t, {{ arg.width_bytes }}> data{};
    std::memcpy(data.data(), &dut->{{ arg.name }}_TDATA, {{ arg.width_bytes }});
    (void)tapa_stream_try_write("{{ arg.name }}", data.data());
  }
{% endfor %}
{% endif %}
}

int main(int argc, char** argv) {
  Verilated::commandArgs(argc, argv);
  dut = new V{{ top_name }};
  dut->ap_clk = 0;
  dut->ap_rst_n = 0;
{% if mode == "hls" %}
  dut->ap_start = 0;
{% endif %}
{% if mode == "vitis" %}
  dut->s_axi_control_AWVALID = 0;
  dut->s_axi_control_WVALID = 0;
  dut->s_axi_control_ARVALID = 0;
  dut->s_axi_control_BREADY = 0;
  dut->s_axi_control_RREADY = 0;
{% endif %}
  for (int i = 0; i < 10; ++i) tick();
  dut->ap_rst_n = 1;
  for (int i = 0; i < 5; ++i) tick();

{% if mode == "hls" %}
{% for arg in mmap_args %}
  dut->{{ arg.name }}_offset = 0x{{ "{:016x}"|format(arg.base_addr) }}ULL;
{% endfor %}
{% for arg in scalar_args %}
  {
    const uint8_t scalar_bytes[] = { {{ arg.bytes_initializer }} };
    std::memset(&dut->{{ arg.name }}, 0, sizeof(dut->{{ arg.name }}));
    std::memcpy(
        &dut->{{ arg.name }},
        scalar_bytes,
        std::min(sizeof(dut->{{ arg.name }}), sizeof(scalar_bytes)));
  }
{% endfor %}
  dut->ap_start = 1;
{% else %}
  ctrl_write(0x04, 1);
  ctrl_write(0x08, 1);
{% for arg in mmap_args %}
  ctrl_write(0x{{ "{:02x}"|format(arg.reg_offset_lo) }}, (uint32_t)(0x{{ "{:016x}"|format(arg.base_addr) }}ULL));
  ctrl_write(0x{{ "{:02x}"|format(arg.reg_offset_hi) }}, (uint32_t)(0x{{ "{:016x}"|format(arg.base_addr) }}ULL >> 32));
{% endfor %}
{% for arg in scalar_args %}
{% for word in arg.words %}
  ctrl_write(0x{{ "{:02x}"|format(word.reg_offset) }}, 0x{{ "{:08x}"|format(word.value_u32) }});
{% endfor %}
{% endfor %}
  ctrl_write(0x00, 1);
{% endif %}

  bool done = false;
  constexpr int kTimeoutCycles = 20000000;
  for (int cycle = 0; cycle < kTimeoutCycles; ++cycle) {
    service_all_axi();
    service_streams();
    tick();
{% if mode == "hls" %}
    if (dut->ap_done) {
      done = true;
      break;
    }
    if (dut->ap_ready) {
      dut->ap_start = 0;
    }
{% else %}
    if (dut->__SYM__interrupt) {
      done = true;
      break;
    }
{% endif %}
  }

  if (!done) {
    std::fprintf(stderr, "simulation timeout\n");
    delete dut;
    return 1;
  }
  std::fprintf(stderr, "simulation complete (mode={{ mode }})\n");
  delete dut;
  return 0;
}
