`timescale 1ns/1ps
module tb_{{ top_name }};

reg ap_clk = 0;
always #5 ap_clk = ~ap_clk;
reg ap_rst_n = 0;

initial begin
  repeat (10) @(posedge ap_clk);
  ap_rst_n = 1;
{% for arg in scalar_args %}
  // scalar {{ arg.name }} value={{ arg.value }}
{% endfor %}
{% for arg in mmap_args %}
  // mmap {{ arg.name }} base=0x{{ "{:016x}"|format(arg.base_addr) }} width_bytes={{ arg.data_width_bytes }}
{% endfor %}
{% for arg in stream_args %}
  // stream-in {{ arg.name }} width_bytes={{ arg.width_bytes }}
{% endfor %}
{% for arg in stream_out_args %}
  // stream-out {{ arg.name }} width_bytes={{ arg.width_bytes }}
{% endfor %}
  repeat (1000) @(posedge ap_clk);
  $finish;
end

endmodule
