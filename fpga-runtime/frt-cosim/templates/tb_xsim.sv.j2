`timescale 1ns/1ps
module tb_{{ top_name }};

import "DPI-C" function void tapa_axi_read(input string port, input longint unsigned addr, input int unsigned width, output byte unsigned out[]);
import "DPI-C" function void tapa_axi_write(input string port, input longint unsigned addr, input int unsigned width, input byte unsigned data[]);
import "DPI-C" function bit tapa_stream_try_read(input string port, output byte unsigned out[]);
import "DPI-C" function bit tapa_stream_try_write(input string port, input byte unsigned data[]);
import "DPI-C" function bit tapa_stream_can_write(input string port);

reg ap_clk = 0;
always #5 ap_clk = ~ap_clk;
reg ap_rst_n = 0;
{% if mode == "hls" %}
reg ap_start = 0;
wire ap_done;
wire ap_ready;
wire ap_idle;
{% endif %}

{% if mode == "vitis" %}
reg s_axi_control_AWVALID = 0;
wire s_axi_control_AWREADY;
reg [7:0] s_axi_control_AWADDR = 0;
reg s_axi_control_WVALID = 0;
wire s_axi_control_WREADY;
reg [31:0] s_axi_control_WDATA = 0;
reg [3:0] s_axi_control_WSTRB = 0;
reg s_axi_control_ARVALID = 0;
wire s_axi_control_ARREADY;
reg [7:0] s_axi_control_ARADDR = 0;
wire s_axi_control_RVALID;
reg s_axi_control_RREADY = 0;
wire [31:0] s_axi_control_RDATA;
wire [1:0] s_axi_control_RRESP;
wire s_axi_control_BVALID;
reg s_axi_control_BREADY = 0;
wire [1:0] s_axi_control_BRESP;
wire interrupt;
{% endif %}

{% if mode == "vitis" %}
task automatic ctrl_write(input [7:0] addr, input [31:0] data);
begin
  s_axi_control_AWVALID <= 1'b1;
  s_axi_control_AWADDR <= addr;
  s_axi_control_WVALID <= 1'b1;
  s_axi_control_WDATA <= data;
  s_axi_control_WSTRB <= 4'hF;
  s_axi_control_BREADY <= 1'b1;
  repeat (64) begin
    @(posedge ap_clk);
    if (s_axi_control_BVALID) begin
      break;
    end
  end
  s_axi_control_AWVALID <= 1'b0;
  s_axi_control_WVALID <= 1'b0;
  s_axi_control_BREADY <= 1'b0;
  @(posedge ap_clk);
end
endtask
{% endif %}

{% for arg in mmap_args %}
wire [63:0] m_axi_{{ arg.name }}_ARADDR;
wire [1:0] m_axi_{{ arg.name }}_ARBURST;
wire [3:0] m_axi_{{ arg.name }}_ARCACHE;
wire [0:0] m_axi_{{ arg.name }}_ARID;
wire [7:0] m_axi_{{ arg.name }}_ARLEN;
wire [1:0] m_axi_{{ arg.name }}_ARLOCK;
wire [2:0] m_axi_{{ arg.name }}_ARPROT;
wire [3:0] m_axi_{{ arg.name }}_ARQOS;
reg  m_axi_{{ arg.name }}_ARREADY = 0;
wire [2:0] m_axi_{{ arg.name }}_ARSIZE;
wire m_axi_{{ arg.name }}_ARVALID;

wire [63:0] m_axi_{{ arg.name }}_AWADDR;
wire [1:0] m_axi_{{ arg.name }}_AWBURST;
wire [3:0] m_axi_{{ arg.name }}_AWCACHE;
wire [0:0] m_axi_{{ arg.name }}_AWID;
wire [7:0] m_axi_{{ arg.name }}_AWLEN;
wire [1:0] m_axi_{{ arg.name }}_AWLOCK;
wire [2:0] m_axi_{{ arg.name }}_AWPROT;
wire [3:0] m_axi_{{ arg.name }}_AWQOS;
reg  m_axi_{{ arg.name }}_AWREADY = 1;
wire [2:0] m_axi_{{ arg.name }}_AWSIZE;
wire m_axi_{{ arg.name }}_AWVALID;

reg [{{ arg.data_width_bytes * 8 - 1 }}:0] m_axi_{{ arg.name }}_RDATA = 0;
reg [0:0] m_axi_{{ arg.name }}_RID = 0;
reg m_axi_{{ arg.name }}_RLAST = 0;
wire m_axi_{{ arg.name }}_RREADY;
reg [1:0] m_axi_{{ arg.name }}_RRESP = 0;
reg m_axi_{{ arg.name }}_RVALID = 0;

wire [{{ arg.data_width_bytes * 8 - 1 }}:0] m_axi_{{ arg.name }}_WDATA;
wire m_axi_{{ arg.name }}_WLAST;
reg  m_axi_{{ arg.name }}_WREADY = 1;
wire [{{ arg.data_width_bytes - 1 }}:0] m_axi_{{ arg.name }}_WSTRB;
wire m_axi_{{ arg.name }}_WVALID;

reg [0:0] m_axi_{{ arg.name }}_BID = 0;
wire m_axi_{{ arg.name }}_BREADY;
reg [1:0] m_axi_{{ arg.name }}_BRESP = 0;
reg m_axi_{{ arg.name }}_BVALID = 0;

byte unsigned axi_{{ arg.name }}_bytes[0:{{ arg.data_width_bytes - 1 }}];
reg axi_{{ arg.name }}_rd_busy = 0;
reg [63:0] axi_{{ arg.name }}_rd_addr = 0;
reg [7:0] axi_{{ arg.name }}_rd_len = 0;
reg [7:0] axi_{{ arg.name }}_rd_beat = 0;
reg [0:0] axi_{{ arg.name }}_rd_id = 0;

reg axi_{{ arg.name }}_wr_aw_got = 0;
reg axi_{{ arg.name }}_wr_b_pending = 0;
reg [63:0] axi_{{ arg.name }}_wr_addr = 0;
reg [7:0] axi_{{ arg.name }}_wr_beat = 0;
reg [0:0] axi_{{ arg.name }}_wr_id = 0;
{% endfor %}

{% for arg in stream_args %}
reg [{{ arg.width_bytes * 8 - 1 }}:0] stream_in_data_{{ arg.name }} = 0;
reg stream_in_have_{{ arg.name }} = 0;
byte unsigned stream_in_bytes_{{ arg.name }}[0:{{ arg.width_bytes - 1 }}];
{% if mode == "hls" %}
wire stream_read_{{ arg.name }};
{% else %}
wire stream_ready_{{ arg.name }};
{% endif %}
{% endfor %}
{% for arg in stream_out_args %}
byte unsigned stream_out_bytes_{{ arg.name }}[0:{{ arg.width_bytes - 1 }}];
wire [{{ arg.width_bytes * 8 - 1 }}:0] stream_out_data_{{ arg.name }};
{% if mode == "hls" %}
wire stream_out_write_{{ arg.name }};
reg stream_out_full_n_{{ arg.name }} = 1'b1;
{% else %}
wire stream_out_valid_{{ arg.name }};
reg stream_out_ready_{{ arg.name }} = 1'b1;
{% endif %}
{% endfor %}

{{ top_name }} dut (
{% for arg in mmap_args %}
{% if mode == "hls" %}
  .{{ arg.name }}_offset(64'h{{ "{:016x}"|format(arg.base_addr) }}),
{% endif %}
  .m_axi_{{ arg.name }}_ARADDR(m_axi_{{ arg.name }}_ARADDR),
  .m_axi_{{ arg.name }}_ARBURST(m_axi_{{ arg.name }}_ARBURST),
  .m_axi_{{ arg.name }}_ARCACHE(m_axi_{{ arg.name }}_ARCACHE),
  .m_axi_{{ arg.name }}_ARID(m_axi_{{ arg.name }}_ARID),
  .m_axi_{{ arg.name }}_ARLEN(m_axi_{{ arg.name }}_ARLEN),
  .m_axi_{{ arg.name }}_ARLOCK(m_axi_{{ arg.name }}_ARLOCK),
  .m_axi_{{ arg.name }}_ARPROT(m_axi_{{ arg.name }}_ARPROT),
  .m_axi_{{ arg.name }}_ARQOS(m_axi_{{ arg.name }}_ARQOS),
  .m_axi_{{ arg.name }}_ARREADY(m_axi_{{ arg.name }}_ARREADY),
  .m_axi_{{ arg.name }}_ARSIZE(m_axi_{{ arg.name }}_ARSIZE),
  .m_axi_{{ arg.name }}_ARVALID(m_axi_{{ arg.name }}_ARVALID),
  .m_axi_{{ arg.name }}_AWADDR(m_axi_{{ arg.name }}_AWADDR),
  .m_axi_{{ arg.name }}_AWBURST(m_axi_{{ arg.name }}_AWBURST),
  .m_axi_{{ arg.name }}_AWCACHE(m_axi_{{ arg.name }}_AWCACHE),
  .m_axi_{{ arg.name }}_AWID(m_axi_{{ arg.name }}_AWID),
  .m_axi_{{ arg.name }}_AWLEN(m_axi_{{ arg.name }}_AWLEN),
  .m_axi_{{ arg.name }}_AWLOCK(m_axi_{{ arg.name }}_AWLOCK),
  .m_axi_{{ arg.name }}_AWPROT(m_axi_{{ arg.name }}_AWPROT),
  .m_axi_{{ arg.name }}_AWQOS(m_axi_{{ arg.name }}_AWQOS),
  .m_axi_{{ arg.name }}_AWREADY(m_axi_{{ arg.name }}_AWREADY),
  .m_axi_{{ arg.name }}_AWSIZE(m_axi_{{ arg.name }}_AWSIZE),
  .m_axi_{{ arg.name }}_AWVALID(m_axi_{{ arg.name }}_AWVALID),
  .m_axi_{{ arg.name }}_BID(m_axi_{{ arg.name }}_BID),
  .m_axi_{{ arg.name }}_BREADY(m_axi_{{ arg.name }}_BREADY),
  .m_axi_{{ arg.name }}_BRESP(m_axi_{{ arg.name }}_BRESP),
  .m_axi_{{ arg.name }}_BVALID(m_axi_{{ arg.name }}_BVALID),
  .m_axi_{{ arg.name }}_RDATA(m_axi_{{ arg.name }}_RDATA),
  .m_axi_{{ arg.name }}_RID(m_axi_{{ arg.name }}_RID),
  .m_axi_{{ arg.name }}_RLAST(m_axi_{{ arg.name }}_RLAST),
  .m_axi_{{ arg.name }}_RREADY(m_axi_{{ arg.name }}_RREADY),
  .m_axi_{{ arg.name }}_RRESP(m_axi_{{ arg.name }}_RRESP),
  .m_axi_{{ arg.name }}_RVALID(m_axi_{{ arg.name }}_RVALID),
  .m_axi_{{ arg.name }}_WDATA(m_axi_{{ arg.name }}_WDATA),
  .m_axi_{{ arg.name }}_WLAST(m_axi_{{ arg.name }}_WLAST),
  .m_axi_{{ arg.name }}_WREADY(m_axi_{{ arg.name }}_WREADY),
  .m_axi_{{ arg.name }}_WSTRB(m_axi_{{ arg.name }}_WSTRB),
  .m_axi_{{ arg.name }}_WVALID(m_axi_{{ arg.name }}_WVALID),
{% endfor %}
{% if mode == "hls" %}
{% for arg in stream_args %}
  .{{ arg.name }}_dout(stream_in_data_{{ arg.name }}),
  .{{ arg.name }}_empty_n(stream_in_have_{{ arg.name }}),
  .{{ arg.name }}_read(stream_read_{{ arg.name }}),
{% if arg.has_peek %}
  .{{ arg.peek_name }}_dout(stream_in_data_{{ arg.name }}),
  .{{ arg.peek_name }}_empty_n(stream_in_have_{{ arg.name }}),
{% endif %}
{% endfor %}
{% for arg in stream_out_args %}
  .{{ arg.name }}_din(stream_out_data_{{ arg.name }}),
  .{{ arg.name }}_full_n(stream_out_full_n_{{ arg.name }}),
  .{{ arg.name }}_write(stream_out_write_{{ arg.name }}),
{% endfor %}
{% for arg in scalar_args %}
  .{{ arg.name }}({{ arg.value_expr }}),
{% endfor %}
  .ap_clk(ap_clk),
  .ap_rst_n(ap_rst_n),
  .ap_start(ap_start),
  .ap_done(ap_done),
  .ap_ready(ap_ready),
  .ap_idle(ap_idle)
{% else %}
{% for arg in stream_args %}
  .{{ arg.name }}_TDATA(stream_in_data_{{ arg.name }}),
  .{{ arg.name }}_TVALID(stream_in_have_{{ arg.name }}),
  .{{ arg.name }}_TREADY(stream_ready_{{ arg.name }}),
  .{{ arg.name }}_TLAST(),
{% endfor %}
{% for arg in stream_out_args %}
  .{{ arg.name }}_TDATA(stream_out_data_{{ arg.name }}),
  .{{ arg.name }}_TVALID(stream_out_valid_{{ arg.name }}),
  .{{ arg.name }}_TREADY(stream_out_ready_{{ arg.name }}),
  .{{ arg.name }}_TLAST(),
{% endfor %}
  .s_axi_control_AWVALID(s_axi_control_AWVALID),
  .s_axi_control_AWREADY(s_axi_control_AWREADY),
  .s_axi_control_AWADDR(s_axi_control_AWADDR),
  .s_axi_control_WVALID(s_axi_control_WVALID),
  .s_axi_control_WREADY(s_axi_control_WREADY),
  .s_axi_control_WDATA(s_axi_control_WDATA),
  .s_axi_control_WSTRB(s_axi_control_WSTRB),
  .s_axi_control_ARVALID(s_axi_control_ARVALID),
  .s_axi_control_ARREADY(s_axi_control_ARREADY),
  .s_axi_control_ARADDR(s_axi_control_ARADDR),
  .s_axi_control_RVALID(s_axi_control_RVALID),
  .s_axi_control_RREADY(s_axi_control_RREADY),
  .s_axi_control_RDATA(s_axi_control_RDATA),
  .s_axi_control_RRESP(s_axi_control_RRESP),
  .s_axi_control_BVALID(s_axi_control_BVALID),
  .s_axi_control_BREADY(s_axi_control_BREADY),
  .s_axi_control_BRESP(s_axi_control_BRESP),
  .ap_clk(ap_clk),
  .ap_rst_n(ap_rst_n),
  .interrupt(interrupt)
{% endif %}
);

integer i;
initial begin
  repeat (10) @(posedge ap_clk);
  ap_rst_n = 1'b1;
  repeat (10) @(posedge ap_clk);
{% if mode == "hls" %}
  ap_start = 1'b1;
  @(posedge ap_clk);
  ap_start = 1'b0;
{% else %}
  ctrl_write(8'h04, 32'h0000_0001);
  ctrl_write(8'h08, 32'h0000_0001);
{% for arg in mmap_args %}
  ctrl_write(8'h{{ "{:02x}"|format(arg.reg_offset_lo) }}, 32'h{{ "{:08x}"|format(arg.base_addr & 0xffffffff) }});
  ctrl_write(8'h{{ "{:02x}"|format(arg.reg_offset_hi) }}, 32'h{{ "{:08x}"|format((arg.base_addr >> 32) & 0xffffffff) }});
{% endfor %}
{% for arg in scalar_args %}
{% for word in arg.words %}
  ctrl_write(8'h{{ "{:02x}"|format(word.reg_offset) }}, 32'h{{ "{:08x}"|format(word.value_u32) }});
{% endfor %}
{% endfor %}
  ctrl_write(8'h00, 32'h0000_0001);
{% endif %}
end

always @(posedge ap_clk) begin
{% for arg in mmap_args %}
  m_axi_{{ arg.name }}_ARREADY <= ~axi_{{ arg.name }}_rd_busy;
  if (m_axi_{{ arg.name }}_ARVALID && m_axi_{{ arg.name }}_ARREADY) begin
    axi_{{ arg.name }}_rd_busy <= 1'b1;
    axi_{{ arg.name }}_rd_addr <= m_axi_{{ arg.name }}_ARADDR;
    axi_{{ arg.name }}_rd_len <= m_axi_{{ arg.name }}_ARLEN;
    axi_{{ arg.name }}_rd_beat <= 0;
    axi_{{ arg.name }}_rd_id <= m_axi_{{ arg.name }}_ARID;
  end
  if (axi_{{ arg.name }}_rd_busy) begin
    tapa_axi_read("{{ arg.name }}", axi_{{ arg.name }}_rd_addr + axi_{{ arg.name }}_rd_beat * {{ arg.data_width_bytes }}, {{ arg.data_width_bytes }}, axi_{{ arg.name }}_bytes);
    for (i = 0; i < {{ arg.data_width_bytes }}; i = i + 1) begin
      m_axi_{{ arg.name }}_RDATA[i*8 +: 8] <= axi_{{ arg.name }}_bytes[i];
    end
    m_axi_{{ arg.name }}_RVALID <= 1'b1;
    m_axi_{{ arg.name }}_RLAST <= (axi_{{ arg.name }}_rd_beat == axi_{{ arg.name }}_rd_len);
    m_axi_{{ arg.name }}_RID <= axi_{{ arg.name }}_rd_id;
    m_axi_{{ arg.name }}_RRESP <= 2'b00;
    if (m_axi_{{ arg.name }}_RREADY) begin
      if (axi_{{ arg.name }}_rd_beat >= axi_{{ arg.name }}_rd_len) begin
        axi_{{ arg.name }}_rd_busy <= 1'b0;
      end else begin
        axi_{{ arg.name }}_rd_beat <= axi_{{ arg.name }}_rd_beat + 1'b1;
      end
    end
  end else begin
    m_axi_{{ arg.name }}_RVALID <= 1'b0;
  end

  m_axi_{{ arg.name }}_AWREADY <= (~axi_{{ arg.name }}_wr_aw_got && ~axi_{{ arg.name }}_wr_b_pending);
  if (m_axi_{{ arg.name }}_AWVALID && m_axi_{{ arg.name }}_AWREADY) begin
    axi_{{ arg.name }}_wr_aw_got <= 1'b1;
    axi_{{ arg.name }}_wr_addr <= m_axi_{{ arg.name }}_AWADDR;
    axi_{{ arg.name }}_wr_beat <= 0;
    axi_{{ arg.name }}_wr_id <= m_axi_{{ arg.name }}_AWID;
  end
  m_axi_{{ arg.name }}_WREADY <= axi_{{ arg.name }}_wr_aw_got;
  if (m_axi_{{ arg.name }}_WVALID && m_axi_{{ arg.name }}_WREADY) begin
    for (i = 0; i < {{ arg.data_width_bytes }}; i = i + 1) begin
      axi_{{ arg.name }}_bytes[i] = m_axi_{{ arg.name }}_WDATA[i*8 +: 8];
    end
    tapa_axi_write("{{ arg.name }}", axi_{{ arg.name }}_wr_addr + axi_{{ arg.name }}_wr_beat * {{ arg.data_width_bytes }}, {{ arg.data_width_bytes }}, axi_{{ arg.name }}_bytes);
    axi_{{ arg.name }}_wr_beat <= axi_{{ arg.name }}_wr_beat + 1'b1;
    if (m_axi_{{ arg.name }}_WLAST) begin
      axi_{{ arg.name }}_wr_aw_got <= 1'b0;
      axi_{{ arg.name }}_wr_b_pending <= 1'b1;
    end
  end
  m_axi_{{ arg.name }}_BVALID <= axi_{{ arg.name }}_wr_b_pending;
  m_axi_{{ arg.name }}_BID <= axi_{{ arg.name }}_wr_id;
  m_axi_{{ arg.name }}_BRESP <= 2'b00;
  if (axi_{{ arg.name }}_wr_b_pending && m_axi_{{ arg.name }}_BREADY) begin
    axi_{{ arg.name }}_wr_b_pending <= 1'b0;
  end
{% endfor %}

{% for arg in stream_args %}
  if (!stream_in_have_{{ arg.name }}) begin
    bit got_stream_{{ arg.name }};
    got_stream_{{ arg.name }} = tapa_stream_try_read("{{ arg.name }}", stream_in_bytes_{{ arg.name }});
    stream_in_have_{{ arg.name }} <= got_stream_{{ arg.name }};
    if (got_stream_{{ arg.name }}) begin
      for (i = 0; i < {{ arg.width_bytes }}; i = i + 1) begin
        stream_in_data_{{ arg.name }}[i*8 +: 8] <= stream_in_bytes_{{ arg.name }}[i];
      end
    end
  end
{% if mode == "hls" %}
  if (stream_in_have_{{ arg.name }} && stream_read_{{ arg.name }}) begin
    stream_in_have_{{ arg.name }} <= 1'b0;
  end
{% else %}
  if (stream_in_have_{{ arg.name }} && stream_ready_{{ arg.name }}) begin
    stream_in_have_{{ arg.name }} <= 1'b0;
  end
{% endif %}
{% endfor %}

{% for arg in stream_out_args %}
{% if mode == "hls" %}
  bit can_write_{{ arg.name }};
  can_write_{{ arg.name }} = tapa_stream_can_write("{{ arg.name }}");
  stream_out_full_n_{{ arg.name }} <= can_write_{{ arg.name }};
  if (stream_out_write_{{ arg.name }} && can_write_{{ arg.name }}) begin
    for (i = 0; i < {{ arg.width_bytes }}; i = i + 1) begin
      stream_out_bytes_{{ arg.name }}[i] = stream_out_data_{{ arg.name }}[i*8 +: 8];
    end
    void'(tapa_stream_try_write("{{ arg.name }}", stream_out_bytes_{{ arg.name }}));
  end
{% else %}
  bit can_write_{{ arg.name }};
  can_write_{{ arg.name }} = tapa_stream_can_write("{{ arg.name }}");
  stream_out_ready_{{ arg.name }} <= can_write_{{ arg.name }};
  if (stream_out_valid_{{ arg.name }} && can_write_{{ arg.name }}) begin
    for (i = 0; i < {{ arg.width_bytes }}; i = i + 1) begin
      stream_out_bytes_{{ arg.name }}[i] = stream_out_data_{{ arg.name }}[i*8 +: 8];
    end
    void'(tapa_stream_try_write("{{ arg.name }}", stream_out_bytes_{{ arg.name }}));
  end
{% endif %}
{% endfor %}
end

initial begin
{% if mode == "hls" %}
  repeat (20000000) begin
    @(posedge ap_clk);
    if (ap_done) begin
      $finish;
    end
  end
{% else %}
  repeat (20000000) begin
    @(posedge ap_clk);
    if (interrupt) begin
      $finish;
    end
  end
{% endif %}
  $display("simulation timeout");
  $finish;
end

endmodule
