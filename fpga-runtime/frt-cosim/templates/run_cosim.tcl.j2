create_project -force cosim {{ tb_dir }}/run -part {{ part_num }}
{% for f in verilog_files %}
add_files {{ f }}
{% endfor %}
add_files {{ tb_sv_file }}
set_property top {{ tb_top }} [get_filesets sim_1]
set_property -name {xsim.elaborate.xelab.more_options} -value {-sv_lib {{ dpi_lib_path }}} -objects [get_filesets sim_1]
{% if save_waveform %}
set_property -name {xsim.simulate.log_all_signals} -value {true} -objects [get_filesets sim_1]
{% endif %}
launch_simulation
run all
close_sim
