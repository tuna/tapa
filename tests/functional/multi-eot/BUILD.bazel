load("@rules_cc//cc:defs.bzl", "cc_binary")
load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("//bazel:tapa_rules.bzl", "tapa_xo")

sh_test(
    name = "multi-eot",
    size = "medium",
    srcs = select({
        "//bazel:is_macos": ["//bazel:sim_env.sh"],
        "//conditions:default": ["//bazel:v++_env.sh"],
    }),
    args = ["$(location multi-eot-host)"] + select({
        "//bazel:is_macos": ["1000"],
        "//conditions:default": [],
    }),
    data = [":multi-eot-host"],
    env = {"TAPA_CONCURRENCY": "2"},
    tags = ["cpu:2"],
)

sh_test(
    name = "multi-eot-xosim",
    size = "enormous",
    timeout = "moderate",
    srcs = ["//bazel:v++_env.sh"],
    args = [
        "$(location multi-eot-host)",
        "--bitstream=$(location multi-eot-xo)",
        "--xosim_executable=$(location //tapa/cosim:tapa-fast-cosim)",
        "1000",
    ],
    data = [
        ":multi-eot-host",
        ":multi-eot-xo",
        "//tapa/cosim:tapa-fast-cosim",
    ],
    tags = [
        "cpu:2",
    ],
)

cc_binary(
    name = "multi-eot-host",
    srcs = glob([
        "*.cpp",
    ]),
    deps = [
        "//tapa-lib:tapa-host",
        "@gflags",
        "@vitis_hls//:include",
    ],
)

sh_test(
    name = "multi-eot-verilator-zipsim",
    size = "enormous",
    timeout = "moderate",
    srcs = ["//bazel:sim_env.sh"],
    args = [
        "$(location multi-eot-host)",
        "--bitstream=$(location multi-eot-zip)",
        "--xosim_executable=$(location //tapa/cosim:tapa-fast-cosim)",
        "--xosim_simulator=verilator",
        "1000",
    ],
    data = [
        ":multi-eot-host",
        ":multi-eot-zip",
        "//tapa/cosim:tapa-fast-cosim",
        "@verilator//:verilator_executable",
    ],
    env = {"VERILATOR_BIN": "$(rootpath @verilator//:verilator_executable)"},
    tags = ["cpu:2"],
)

tapa_xo(
    name = "multi-eot-xo",
    src = "vadd.cpp",
    top_name = "VecAdd",
)

tapa_xo(
    name = "multi-eot-zip",
    src = "vadd.cpp",
    target = "xilinx-hls",
    top_name = "VecAdd",
)
