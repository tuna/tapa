load("@rules_cc//cc:defs.bzl", "cc_binary")
load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("//bazel:tapa_rules.bzl", "tapa_xo")

sh_test(
    name = "stream-top",
    size = "medium",
    srcs = select({
        "//bazel:is_macos": ["//bazel:sim_env.sh"],
        "//conditions:default": ["//bazel:v++_env.sh"],
    }),
    args = ["$(location stream-top-host)"] + select({
        "//bazel:is_macos": ["1000"],
        "//conditions:default": [],
    }),
    data = [":stream-top-host"],
    env = {"TAPA_CONCURRENCY": "2"},
    tags = ["cpu:2"],
)

sh_test(
    name = "stream-top-xosim",
    size = "enormous",
    timeout = "moderate",
    srcs = ["//bazel:v++_env.sh"],
    args = [
        "$(location stream-top-host)",
        "--bitstream=$(location stream-top-xo)",
    ],
    data = [
        ":stream-top-host",
        ":stream-top-xo",
        "//fpga-runtime:cargo_release_artifacts",
    ],
    tags = [
        "cpu:3",
    ],
)

sh_test(
    name = "stream-top-hls-zipsim",
    size = "enormous",
    timeout = "moderate",
    srcs = ["//bazel:v++_env.sh"],
    args = [
        "$(location stream-top-host)",
        "--bitstream=$(location stream-top-hls-zip)",
    ],
    data = [
        ":stream-top-hls-zip",
        ":stream-top-host",
        "//fpga-runtime:cargo_release_artifacts",
    ],
    tags = [
        "cpu:3",
    ],
)

tapa_xo(
    name = "stream-top-xo",
    src = "vadd.cpp",
    hdrs = glob(["*.h"]),
    top_name = "StreamAdd_XRT",
)

cc_binary(
    name = "stream-top-host",
    srcs = glob([
        "*.cpp",
        "*.h",
    ]),
    deps = [
        "//tapa-lib:tapa-host",
        "@gflags",
        "@vitis_hls//:include",
    ],
)

tapa_xo(
    name = "stream-top-hls-zip",
    src = "vadd.cpp",
    hdrs = glob(["*.h"]),
    target = "xilinx-hls",
    top_name = "StreamAdd",
)
