load("@rules_cc//cc:defs.bzl", "cc_binary")
load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("//bazel:tapa_rules.bzl", "tapa_xo")

sh_test(
    name = "mmaps-streams",
    size = "medium",
    srcs = select({
        "//bazel:is_macos": ["//bazel:sim_env.sh"],
        "//conditions:default": ["//bazel:v++_env.sh"],
    }),
    args = ["$(location mmaps-streams-host)"] + select({
        "//bazel:is_macos": ["1000"],
        "//conditions:default": [],
    }),
    data = [":mmaps-streams-host"],
    env = {"TAPA_CONCURRENCY": "2"},
    tags = ["cpu:2"],
)

sh_test(
    name = "mmaps-streams-xosim",
    size = "enormous",
    timeout = "moderate",
    srcs = ["//bazel:v++_env.sh"],
    args = [
        "$(location mmaps-streams-host)",
        "--bitstream=$(location mmaps-streams-xo)",
        "1000",
    ],
    data = [
        ":mmaps-streams-host",
        ":mmaps-streams-xo",
    ],
    tags = [
        "cpu:2",
    ],
)

cc_binary(
    name = "mmaps-streams-host",
    srcs = glob([
        "*.cpp",
        "*.h",
    ]),
    deps = [
        "//tapa-lib:tapa-host",
        "@gflags",
        "@vitis_hls//:include",
    ],
)

tapa_xo(
    name = "mmaps-streams-xo",
    src = "vadd.cpp",
    hdrs = glob(["*.h"]),
    top_name = "VecAdd",
)
