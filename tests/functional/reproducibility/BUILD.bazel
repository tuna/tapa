load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("//bazel:tapa_rules.bzl", "tapa_reuse_work_dir_xo", "tapa_xo")

tapa_xo(
    name = "vadd-xo",
    src = "//tests/apps/vadd:vadd.cpp",
    hdrs = ["//tests/apps/vadd:vadd.h"],
    include = ["//tests/apps/vadd:."],
    top_name = "VecAdd",
)

sh_test(
    name = "reproducible-xo-test",
    srcs = ["zip-diff.sh"],
    args = [
        "$(location :vadd-xo)",
        "$(location //tests/apps/vadd:vadd-xo)",
    ],
    data = [
        ":vadd-xo",
        "//tests/apps/vadd:vadd-xo",
    ],
)

tapa_xo(
    name = "vadd-zip",
    src = "//tests/apps/vadd:vadd.cpp",
    hdrs = ["//tests/apps/vadd:vadd.h"],
    include = ["//tests/apps/vadd:."],
    target = "xilinx-hls",
    top_name = "VecAdd",
)

sh_test(
    name = "reproducible-zip-test",
    srcs = ["zip-diff.sh"],
    args = [
        "$(location :vadd-zip)",
        "$(location //tests/apps/vadd:vadd-zip)",
    ],
    data = [
        ":vadd-zip",
        "//tests/apps/vadd:vadd-zip",
    ],
)

tapa_reuse_work_dir_xo(
    name = "reuse-work-dir-vadd-xo",
    src = "//tests/apps/vadd:vadd.cpp",
    hdrs = ["//tests/apps/vadd:vadd.h"],
    include = ["//tests/apps/vadd:."],
    top_name = "VecAdd",
)

# XO generated step-by-step should be the same as XO generated in one step.
sh_test(
    name = "reuse-work-dir-test",
    srcs = ["zip-diff.sh"],
    args = [
        "$(location :reuse-work-dir-vadd-xo)",
        "$(location //tests/apps/vadd:vadd-xo)",
    ],
    data = [
        ":reuse-work-dir-vadd-xo",
        "//tests/apps/vadd:vadd-xo",
    ],
)
