load("@rules_cc//cc:defs.bzl", "cc_binary")
load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("//bazel:tapa_rules.bzl", "tapa_xo")

sh_test(
    name = "detached",
    size = "small",
    srcs = select({
        "//bazel:is_macos": ["//bazel:sim_env.sh"],
        "//conditions:default": ["//bazel:v++_env.sh"],
    }),
    args = ["$(location detached-host)"] + select({
        "//bazel:is_macos": ["1000"],
        "//conditions:default": [],
    }),
    data = [":detached-host"],
    env = {"TAPA_CONCURRENCY": "2"},
    tags = ["cpu:2"],
)

sh_test(
    name = "detached-xosim",
    size = "medium",
    srcs = ["//bazel:v++_env.sh"],
    args = [
        "$(location detached-host)",
        "--bitstream=$(location detached-xo)",
        "1000",
    ],
    data = [
        ":detached-host",
        ":detached-xo",
    ],
)

cc_binary(
    name = "detached-host",
    srcs = glob([
        "*.cpp",
    ]),
    deps = [
        "//tapa-lib:tapa-host",
        "@gflags",
        "@vitis_hls//:include",
    ],
)

tapa_xo(
    name = "detached-xo",
    src = "vadd.cpp",
    top_name = "VecAddDetach",
)
