    name = "task_test",
    srcs = ["task_test.py"],
    deps = [
        ":codegen",
        ":core",
        ":task",
    ],
)

py_library(
    name = "util",
    srcs = ["util.py"],
    deps = [
        requirement("coloredlogs"),
    ],
)

py_test(
    name = "util_test",
    srcs = ["util_test.py"],
    deps = [
        ":util",
    ],
)

# Ship the native Rust `tapa` binary as `usr/share/tapa/runtime/tapa`
# (AC-8). The Python+nuitka `tapa-bin` it replaces was retired with
# `tapa/__main__.py`; the entry point is `//tapa-core:tapa-cli`.
pkg_files(
    name = "pkg-runtime",
    srcs = ["//tapa-core:tapa-cli"],
    attributes = pkg_attributes(mode = "0755"),
    prefix = "usr/share/tapa/runtime",
    renames = {"//tapa-core:tapa-cli": "tapa"},
    visibility = ["//visibility:public"],
)

# link usr/share/tapa/runtime/tapa to /usr/bin/tapa
pkg_mklink(
    name = "pkg-link",
    link_name = "usr/bin/tapa",
    target = "../share/tapa/runtime/tapa",
    visibility = ["//visibility:public"],
)

pkg_filegroup(
    name = "pkg",
    srcs = [
        ":pkg-link",
        ":pkg-runtime",
    ],
    visibility = ["//visibility:public"],
)
