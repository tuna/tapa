
  parameter HALF_CLOCK_PERIOD = 2;
  parameter CLOCK_PERIOD = HALF_CLOCK_PERIOD * 2;

  // clock
  always begin
      ap_clk = 1'b0;
      #HALF_CLOCK_PERIOD;
      ap_clk = 1'b1;
      #HALF_CLOCK_PERIOD;
  end

  // fifo signals
  always @(posedge ap_clk) begin
    if (kernel_started) begin
      {{ fifo_dpi_calls }}
    end
    if (ap_done) begin
      kernel_done <= 1'b1;
    end
    if (ap_ready) begin
      ap_start <= 1'b0;
    end
  end

{{ fifo_assignments }}

  initial begin
    // reset the DUT
    ap_rst_n = 1'b0;
    #(CLOCK_PERIOD*1000);

    // enable the DUT
    ap_rst_n = 1'b1;
    #(CLOCK_PERIOD*100);

    // start the DUT
    ap_start <= 1'b1;
    @(posedge ap_clk);

    kernel_started <= 1;
    @(posedge ap_clk);

    wait(kernel_done);

{{ dump_signals }}

    #(CLOCK_PERIOD*100);
    $finish;
  end
