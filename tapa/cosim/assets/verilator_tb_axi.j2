static void service_all_axi() {
{% for axi in axi_list %}
    // AXI read service for {{ axi.name }}
    dut->m_axi_{{ axi.name }}_ARREADY = !rd_{{ axi.name }}.busy;
    if (dut->m_axi_{{ axi.name }}_ARVALID && !rd_{{ axi.name }}.busy) {
        rd_{{ axi.name }}.busy = true;
        rd_{{ axi.name }}.addr = dut->m_axi_{{ axi.name }}_ARADDR;
        rd_{{ axi.name }}.len = dut->m_axi_{{ axi.name }}_ARLEN;
        rd_{{ axi.name }}.id = dut->m_axi_{{ axi.name }}_ARID;
        rd_{{ axi.name }}.beat = 0;
    }
    if (rd_{{ axi.name }}.busy) {
        dut->m_axi_{{ axi.name }}_RVALID = 1;
        mem_read(rd_{{ axi.name }}.addr + (uint64_t)rd_{{ axi.name }}.beat * {{ axi.data_bytes }},
                 &dut->m_axi_{{ axi.name }}_RDATA, {{ axi.data_bytes }});
        dut->m_axi_{{ axi.name }}_RLAST = (rd_{{ axi.name }}.beat == rd_{{ axi.name }}.len) ? 1 : 0;
        dut->m_axi_{{ axi.name }}_RID = rd_{{ axi.name }}.id;
        dut->m_axi_{{ axi.name }}_RRESP = 0;
        if (dut->m_axi_{{ axi.name }}_RREADY) {
            if (rd_{{ axi.name }}.beat >= rd_{{ axi.name }}.len) rd_{{ axi.name }}.busy = false;
            else rd_{{ axi.name }}.beat++;
        }
    } else {
        dut->m_axi_{{ axi.name }}_RVALID = 0;
    }
    // AXI write service for {{ axi.name }}
    dut->m_axi_{{ axi.name }}_AWREADY = (!wr_{{ axi.name }}.aw_got && !wr_{{ axi.name }}.b_pending) ? 1 : 0;
    if (dut->m_axi_{{ axi.name }}_AWVALID && dut->m_axi_{{ axi.name }}_AWREADY) {
        wr_{{ axi.name }}.aw_got = true;
        wr_{{ axi.name }}.addr = dut->m_axi_{{ axi.name }}_AWADDR;
        wr_{{ axi.name }}.id = dut->m_axi_{{ axi.name }}_AWID;
        wr_{{ axi.name }}.beat = 0;
    }
    dut->m_axi_{{ axi.name }}_WREADY = wr_{{ axi.name }}.aw_got ? 1 : 0;
    if (dut->m_axi_{{ axi.name }}_WVALID && dut->m_axi_{{ axi.name }}_WREADY) {
        mem_write(wr_{{ axi.name }}.addr + (uint64_t)wr_{{ axi.name }}.beat * {{ axi.data_bytes }},
                  &dut->m_axi_{{ axi.name }}_WDATA, dut->m_axi_{{ axi.name }}_WSTRB,
                  {{ axi.data_bytes }});
        wr_{{ axi.name }}.beat++;
        if (dut->m_axi_{{ axi.name }}_WLAST) {
            wr_{{ axi.name }}.aw_got = false;
            wr_{{ axi.name }}.b_pending = true;
        }
    }
    dut->m_axi_{{ axi.name }}_BVALID = wr_{{ axi.name }}.b_pending ? 1 : 0;
    dut->m_axi_{{ axi.name }}_BID = wr_{{ axi.name }}.id;
    dut->m_axi_{{ axi.name }}_BRESP = 0;
    if (wr_{{ axi.name }}.b_pending && dut->m_axi_{{ axi.name }}_BREADY)
        wr_{{ axi.name }}.b_pending = false;
{% endfor %}
}

{% if mode == "vitis" %}
static void ctrl_write(uint8_t addr, uint32_t data) {
    dut->s_axi_control_AWVALID = 1;
    dut->s_axi_control_AWADDR = addr;
    dut->s_axi_control_WVALID = 1;
    dut->s_axi_control_WDATA = data;
    dut->s_axi_control_WSTRB = 0xF;
    dut->s_axi_control_BREADY = 1;
    for (int i = 0; i < 20; i++) {
        service_all_axi(); tick();
        if (dut->s_axi_control_BVALID) break;
    }
    dut->s_axi_control_AWVALID = 0;
    dut->s_axi_control_WVALID = 0;
    dut->s_axi_control_BREADY = 0;
    service_all_axi(); tick();
}

{% endif %}
