#include <cstdio>
#include <cstdlib>
#include <cstring>
#include <fstream>
#include <map>
#include <vector>
#include "V{{ top_name }}.h"
#include "verilated.h"

static std::map<uint64_t, uint8_t> memory;

static void mem_read(uint64_t addr, void* buf, size_t nbytes) {
    auto* dst = reinterpret_cast<uint8_t*>(buf);
    for (size_t i = 0; i < nbytes; i++)
        dst[i] = memory[addr + i];
}

static void mem_write(uint64_t addr, const void* buf, uint64_t strb, size_t nbytes) {
    auto* src = reinterpret_cast<const uint8_t*>(buf);
    for (size_t i = 0; i < nbytes; i++)
        if (strb & (1ULL << i))
            memory[addr + i] = src[i];
}

static void load_binary(const char* path, uint64_t base, size_t size) {
    std::ifstream f(path, std::ios::binary);
    if (!f) { fprintf(stderr, "Cannot open %s\n", path); return; }
    std::vector<char> buf(size);
    f.read(buf.data(), size);
    size_t n = f.gcount();
    for (size_t i = 0; i < n; i++) memory[base + i] = (uint8_t)buf[i];
}

static void dump_binary(const char* path, uint64_t base, size_t size) {
    std::ofstream f(path, std::ios::binary);
    for (size_t i = 0; i < size; i++)
        f.put((char)memory[base + i]);
}

struct AxiReadPort {
    bool busy = false;
    uint64_t addr = 0;
    uint8_t len = 0, beat = 0, id = 0;
};

struct AxiWritePort {
    bool aw_got = false, b_pending = false;
    uint64_t addr = 0;
    uint8_t beat = 0, id = 0;
};

{% for axi in axi_list %}
static AxiReadPort rd_{{ axi.name }};
static AxiWritePort wr_{{ axi.name }};
{% endfor %}

static V{{ top_name }}* dut;

static void tick() {
    dut->ap_clk = 1; dut->eval();
    dut->ap_clk = 0; dut->eval();
}

static void service_all_axi();
{% if mode == "vitis" %}
static void ctrl_write(uint8_t addr, uint32_t data);
{% endif %}
{% if stream_args %}

#include <queue>

struct StreamQueue {
    std::queue<std::vector<uint8_t>> data;
    size_t width_bytes;
    bool eot_sent = false;
};

{% for arg in stream_args %}
static StreamQueue stream_{{ arg.qualified_name }}{{ '{' }}{{ '{}' }}, {{ arg.width_bytes }}{{ '}' }};
{% endfor %}

static void load_stream(StreamQueue& sq, const char* path) {
    std::ifstream f(path, std::ios::binary);
    if (!f) return;
    while (f.peek() != EOF) {
        std::vector<uint8_t> buf(sq.width_bytes);
        f.read(reinterpret_cast<char*>(buf.data()), sq.width_bytes);
        size_t n = f.gcount();
        buf.resize(n);
        if (n > 0) sq.data.push(std::move(buf));
    }
}

static void dump_stream(StreamQueue& sq, const char* path) {
    std::ofstream f(path, std::ios::binary);
    while (!sq.data.empty()) {
        auto& buf = sq.data.front();
        f.write(reinterpret_cast<const char*>(buf.data()), buf.size());
        sq.data.pop();
    }
}

{% endif %}

int main(int argc, char** argv) {
    Verilated::commandArgs(argc, argv);
    dut = new V{{ top_name }};

    dut->ap_clk = 0;
    dut->ap_rst_n = 0;
{% if mode == "vitis" %}
    dut->s_axi_control_AWVALID = 0;
    dut->s_axi_control_WVALID = 0;
    dut->s_axi_control_ARVALID = 0;
    dut->s_axi_control_BREADY = 0;
    dut->s_axi_control_RREADY = 0;
{% else %}
    dut->ap_start = 0;
{% endif %}
{% for axi in axi_list %}
    dut->m_axi_{{ axi.name }}_ARREADY = 0;
    dut->m_axi_{{ axi.name }}_RVALID = 0;
{% if axi.data_width > wide_rdata_width %}
    memset(&dut->m_axi_{{ axi.name }}_RDATA, 0, sizeof(dut->m_axi_{{ axi.name }}_RDATA));
{% else %}
    dut->m_axi_{{ axi.name }}_RDATA = 0;
{% endif %}
    dut->m_axi_{{ axi.name }}_RLAST = 0; dut->m_axi_{{ axi.name }}_RID = 0; dut->m_axi_{{ axi.name }}_RRESP = 0;
    dut->m_axi_{{ axi.name }}_AWREADY = 1; dut->m_axi_{{ axi.name }}_WREADY = 1;
    dut->m_axi_{{ axi.name }}_BVALID = 0; dut->m_axi_{{ axi.name }}_BID = 0; dut->m_axi_{{ axi.name }}_BRESP = 0;
{% endfor %}
{% for arg in stream_args %}
{% if arg.is_istream %}
    dut->{{ arg.qualified_name }}_dout = 0;
    dut->{{ arg.qualified_name }}_empty_n = 0;
{% elif arg.is_ostream %}
    dut->{{ arg.qualified_name }}_full_n = 1;
{% endif %}
{% endfor %}

    for (int i = 0; i < 10; i++) tick();
    dut->ap_rst_n = 1;
    for (int i = 0; i < 5; i++) tick();

{% for axi in axi_list %}
    const uint64_t {{ axi.name }}_BASE = {{ axi.base_addr }};
    const size_t {{ axi.name }}_SIZE = {{ axi.byte_size }};
{% if axi.data_path %}
    load_binary("{{ axi.data_path }}", {{ axi.name }}_BASE, {{ axi.name }}_SIZE);
{% endif %}
{% endfor %}

{% for arg in stream_args %}
{% if arg.data_path %}
    load_stream(stream_{{ arg.qualified_name }}, "{{ arg.data_path }}");
{% endif %}
{% endfor %}

{% if mode == "vitis" %}
    ctrl_write(0x04, 1);  // GIE
    ctrl_write(0x08, 1);  // IER

{% for write in ctrl_writes %}
    ctrl_write({{ write.addr }}, {{ write.val }});
{% endfor %}

    ctrl_write(0x00, 1);
{% else %}
{% for arg in mmap_args %}
    dut->{{ arg.name }}_offset = {{ arg.base_addr }};
{% endfor %}
{% for arg in scalar_args %}
    dut->{{ arg.name }} = {{ arg.hex_val }};
{% endfor %}

    dut->ap_start = 1;
    service_all_axi();
    tick();
{% endif %}
    printf("Kernel started, running simulation...\n");

    bool done = false;
    int timeout = 50000000;
    for (int cycle = 0; cycle < timeout; cycle++) {
        service_all_axi();
{% for arg in stream_args %}
{% if arg.is_istream %}
        if (dut->{{ arg.qualified_name }}_read && dut->{{ arg.qualified_name }}_empty_n)
            stream_{{ arg.qualified_name }}.data.pop();
        if (!stream_{{ arg.qualified_name }}.data.empty()) {
            dut->{{ arg.qualified_name }}_empty_n = 1;
            memcpy(&dut->{{ arg.qualified_name }}_dout, stream_{{ arg.qualified_name }}.data.front().data(), {{ arg.width_bytes }});
        } else dut->{{ arg.qualified_name }}_empty_n = 0;
{% elif arg.is_ostream %}
        if (dut->{{ arg.qualified_name }}_write && dut->{{ arg.qualified_name }}_full_n) {
            std::vector<uint8_t> buf({{ arg.width_bytes }});
            memcpy(buf.data(), &dut->{{ arg.qualified_name }}_din, {{ arg.width_bytes }});
            stream_{{ arg.qualified_name }}.data.push(std::move(buf));
        }
        dut->{{ arg.qualified_name }}_full_n = 1;
{% endif %}
{% endfor %}
        tick();
{% if mode == "vitis" %}
        if (dut->__SYM__interrupt) {
            printf("Kernel done after %d cycles\n", cycle);
            done = true;
            break;
        }
{% else %}
        if (dut->ap_done) {
            printf("Kernel done after %d cycles\n", cycle);
            done = true;
            break;
        }
        if (dut->ap_ready) {
            dut->ap_start = 0;
        }
{% endif %}
    }

    if (!done) {
        printf("TIMEOUT: kernel did not complete in %d cycles\n", timeout);
        delete dut;
        return 1;
    }

{% for axi in axi_list %}
{% if axi.data_path %}
    dump_binary("{{ axi.out_data_path }}", {{ axi.name }}_BASE, {{ axi.name }}_SIZE);
{% endif %}
{% endfor %}
{% for arg in stream_args %}
{% if arg.is_ostream and arg.data_path %}
    dump_stream(stream_{{ arg.qualified_name }}, "{{ arg.out_data_path }}");
{% endif %}
{% endfor %}

    printf("Simulation completed successfully\n");
    delete dut;
    return 0;
}

static void service_all_axi() {
{% for axi in axi_list %}
    // AXI read service for {{ axi.name }}
    dut->m_axi_{{ axi.name }}_ARREADY = !rd_{{ axi.name }}.busy;
    if (dut->m_axi_{{ axi.name }}_ARVALID && !rd_{{ axi.name }}.busy) {
        rd_{{ axi.name }}.busy = true;
        rd_{{ axi.name }}.addr = dut->m_axi_{{ axi.name }}_ARADDR;
        rd_{{ axi.name }}.len = dut->m_axi_{{ axi.name }}_ARLEN;
        rd_{{ axi.name }}.id = dut->m_axi_{{ axi.name }}_ARID;
        rd_{{ axi.name }}.beat = 0;
    }
    if (rd_{{ axi.name }}.busy) {
        dut->m_axi_{{ axi.name }}_RVALID = 1;
        mem_read(rd_{{ axi.name }}.addr + (uint64_t)rd_{{ axi.name }}.beat * {{ axi.data_bytes }},
                 &dut->m_axi_{{ axi.name }}_RDATA, {{ axi.data_bytes }});
        dut->m_axi_{{ axi.name }}_RLAST = (rd_{{ axi.name }}.beat == rd_{{ axi.name }}.len) ? 1 : 0;
        dut->m_axi_{{ axi.name }}_RID = rd_{{ axi.name }}.id;
        dut->m_axi_{{ axi.name }}_RRESP = 0;
        if (dut->m_axi_{{ axi.name }}_RREADY) {
            if (rd_{{ axi.name }}.beat >= rd_{{ axi.name }}.len) rd_{{ axi.name }}.busy = false;
            else rd_{{ axi.name }}.beat++;
        }
    } else {
        dut->m_axi_{{ axi.name }}_RVALID = 0;
    }
    // AXI write service for {{ axi.name }}
    dut->m_axi_{{ axi.name }}_AWREADY = (!wr_{{ axi.name }}.aw_got && !wr_{{ axi.name }}.b_pending) ? 1 : 0;
    if (dut->m_axi_{{ axi.name }}_AWVALID && dut->m_axi_{{ axi.name }}_AWREADY) {
        wr_{{ axi.name }}.aw_got = true;
        wr_{{ axi.name }}.addr = dut->m_axi_{{ axi.name }}_AWADDR;
        wr_{{ axi.name }}.id = dut->m_axi_{{ axi.name }}_AWID;
        wr_{{ axi.name }}.beat = 0;
    }
    dut->m_axi_{{ axi.name }}_WREADY = wr_{{ axi.name }}.aw_got ? 1 : 0;
    if (dut->m_axi_{{ axi.name }}_WVALID && dut->m_axi_{{ axi.name }}_WREADY) {
        mem_write(wr_{{ axi.name }}.addr + (uint64_t)wr_{{ axi.name }}.beat * {{ axi.data_bytes }},
                  &dut->m_axi_{{ axi.name }}_WDATA, dut->m_axi_{{ axi.name }}_WSTRB,
                  {{ axi.data_bytes }});
        wr_{{ axi.name }}.beat++;
        if (dut->m_axi_{{ axi.name }}_WLAST) {
            wr_{{ axi.name }}.aw_got = false;
            wr_{{ axi.name }}.b_pending = true;
        }
    }
    dut->m_axi_{{ axi.name }}_BVALID = wr_{{ axi.name }}.b_pending ? 1 : 0;
    dut->m_axi_{{ axi.name }}_BID = wr_{{ axi.name }}.id;
    dut->m_axi_{{ axi.name }}_BRESP = 0;
    if (wr_{{ axi.name }}.b_pending && dut->m_axi_{{ axi.name }}_BREADY)
        wr_{{ axi.name }}.b_pending = false;
{% endfor %}
}
{% if mode == "vitis" %}

static void ctrl_write(uint8_t addr, uint32_t data) {
    dut->s_axi_control_AWVALID = 1;
    dut->s_axi_control_AWADDR = addr;
    dut->s_axi_control_WVALID = 1;
    dut->s_axi_control_WDATA = data;
    dut->s_axi_control_WSTRB = 0xF;
    dut->s_axi_control_BREADY = 1;
    for (int i = 0; i < 20; i++) {
        service_all_axi(); tick();
        if (dut->s_axi_control_BVALID) break;
    }
    dut->s_axi_control_AWVALID = 0;
    dut->s_axi_control_WVALID = 0;
    dut->s_axi_control_BREADY = 0;
    service_all_axi(); tick();
}
{% endif %}
