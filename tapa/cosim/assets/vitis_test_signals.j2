
  parameter HALF_CLOCK_PERIOD = 2;
  parameter CLOCK_PERIOD = HALF_CLOCK_PERIOD * 2;

  // clock
  always begin
      ap_clk = 1'b0;
      #HALF_CLOCK_PERIOD;
      ap_clk = 1'b1;
      #HALF_CLOCK_PERIOD;
  end

  // axis signals
  always @(posedge ap_clk) begin
    if (kernel_started) begin
{% for arg in ctx.stream_args %}
{% if arg.direction == "istream" %}
    tapa::istream(
        axis_{{ arg.name }}_tdata_unpacked_next,
        axis_{{ arg.name }}_tvalid_next,
        axis_{{ arg.name }}_tready,
        "{{ arg.qualified_name }}"
    );

    axis_{{ arg.name }}_tdata_unpacked <= axis_{{ arg.name }}_tdata_unpacked_next;
    axis_{{ arg.name }}_tvalid <= axis_{{ arg.name }}_tvalid_next;
{% else %}
    tapa::ostream(
        axis_{{ arg.name }}_tdata_unpacked,
        axis_{{ arg.name }}_tready_next,
        axis_{{ arg.name }}_tvalid,
        "{{ arg.qualified_name }}"
    );

    axis_{{ arg.name }}_tready <= axis_{{ arg.name }}_tready_next;
{% endif %}
{% endfor %}
    end
  end

{% for arg in ctx.stream_args %}
{% if arg.direction == "istream" %}
    assign {axis_{{ arg.name }}_tlast, axis_{{ arg.name }}_tdata} =
        packed_uint{{ arg.data_width + 1 }}_t'(axis_{{ arg.name }}_tdata_unpacked);
{% else %}
    assign axis_{{ arg.name }}_tdata_unpacked =
        unpacked_uint{{ arg.data_width + 1 }}_t'
            ({axis_{{ arg.name }}_tlast, axis_{{ arg.name }}_tdata});
{% endif %}
{% endfor %}

  initial begin
    // reset the DUT
    ap_rst_n = 1'b0;
    #(CLOCK_PERIOD*1000);

    // enable the DUT
    ap_rst_n = 1'b1;
    #(CLOCK_PERIOD*100);

{% for write in ctx.register_writes %}
    s_axi_aw_write <= 1; s_axi_aw_din <= {{ write.address }}; s_axi_w_write <= 1; s_axi_w_din <= {% if write.upper_word %}({{ write.value }} >> 32){% else %}{{ write.value }}{% endif %} & REG_MASK_32_BIT; @(posedge ap_clk);
{% endfor %}
    // start the DUT
    s_axi_aw_write <= 1;
    s_axi_aw_din <= 'h00;
    s_axi_w_write <= 1;
    s_axi_w_din <= 1;
    @(posedge ap_clk);

    // stop writing control signal
    s_axi_aw_write <= 0;
    s_axi_w_write <= 0;
    @(posedge ap_clk);

    kernel_started <= 1;
    @(posedge ap_clk);

    // start polling ap_done (keep arvalid asserted unconditionally so
    // the handshake completes even if arready is low at this instant)
    #(CLOCK_PERIOD*1000);
    s_axi_control_arvalid <= 1'b1;
    @(posedge ap_clk);

  end

  // polling on ap_done
  always @(posedge ap_clk) begin
    if (~ap_rst_n) begin
    end
    else begin
      if (s_axi_control_rvalid) begin
        if (s_axi_control_rdata[1]) begin
{% for name in ctx.mmap_names %}
          axi_ram_{{ name }}_dump_mem <= 1;
{% endfor %}
          #(CLOCK_PERIOD*100)
          $finish;
        end
      end
    end
  end
