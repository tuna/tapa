
  parameter HALF_CLOCK_PERIOD = 2;
  parameter CLOCK_PERIOD = HALF_CLOCK_PERIOD * 2;

  // clock
  always begin
      ap_clk = 1'b0;
      #HALF_CLOCK_PERIOD;
      ap_clk = 1'b1;
      #HALF_CLOCK_PERIOD;
  end

  // axis signals
  always @(posedge ap_clk) begin
    if (kernel_started) begin
      {{ axis_dpi_calls }}
    end
  end

{{ axis_assignments }}

  initial begin
    // reset the DUT
    ap_rst_n = 1'b0;
    #(CLOCK_PERIOD*1000);

    // enable the DUT
    ap_rst_n = 1'b1;
    #(CLOCK_PERIOD*100);

{% for write in register_writes %}
    s_axi_aw_write <= 1; s_axi_aw_din <= {{ write.address }}; s_axi_w_write <= 1; s_axi_w_din <= {% if write.upper_word %}({{ write.value }} >> 32){% else %}{{ write.value }}{% endif %} & REG_MASK_32_BIT; @(posedge ap_clk);
{% endfor %}
    // start the DUT
    s_axi_aw_write <= 1;
    s_axi_aw_din <= 'h00;
    s_axi_w_write <= 1;
    s_axi_w_din <= 1;
    @(posedge ap_clk);

    // stop writing control signal
    s_axi_aw_write <= 0;
    s_axi_w_write <= 0;
    @(posedge ap_clk);

    kernel_started <= 1;
    @(posedge ap_clk);

    // start polling ap_done
    #(CLOCK_PERIOD*1000);
    s_axi_control_arvalid <= 1'b1 & s_axi_control_arready;
    @(posedge ap_clk);

  end

  // polling on ap_done
  always @(posedge ap_clk) begin
    if (~ap_rst_n) begin
    end
    else begin
      if (s_axi_control_rvalid) begin
        if (s_axi_control_rdata[1]) begin
{{ dump_signals }}
          #(CLOCK_PERIOD*100)
          $finish;
        end
      end
    end
  end
